<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="create-notifications-table" author="oms-dev" context="base">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="notifications"/>
            </not>
        </preConditions>
        <createTable tableName="notifications">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="tipo" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="estado" type="VARCHAR(20)" defaultValue="PENDIENTE">
                <constraints nullable="false"/>
            </column>
            <column name="mensaje" type="TEXT"/>
            <column name="fecha_envio" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="add-notifications-foreign-key" author="oms-dev" context="base">
        <addForeignKeyConstraint
                baseTableName="notifications"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_notif_user"
                onDelete="CASCADE"
                onUpdate="CASCADE"/>
    </changeSet>

    <changeSet id="add-notifications-order-foreign-key" author="oms-dev" context="base">
        <addForeignKeyConstraint
                baseTableName="notifications"
                baseColumnNames="order_id"
                referencedTableName="orders"
                referencedColumnNames="id"
                constraintName="fk_notif_order"
                onDelete="CASCADE"
                onUpdate="CASCADE"/>
    </changeSet>

    <changeSet id="add-notifications-indexes" author="oms-dev" context="base">
        <createIndex tableName="notifications" indexName="idx_notif_user">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="notifications" indexName="idx_notif_order">
            <column name="order_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="add-notifications-constraints" author="oms-dev" context="base">
        <sql>
            ALTER TABLE notifications
            ADD CONSTRAINT ck_notif_tipo
            CHECK (tipo IN ('CONFIRMACION', 'PAGO', 'ENVIO', 'CANCELACION'))
        </sql>
        <sql>
            ALTER TABLE notifications
            ADD CONSTRAINT ck_notif_estado
            CHECK (estado IN ('PENDIENTE', 'ENVIADA', 'FALLIDA'))
        </sql>
    </changeSet>

</databaseChangeLog>
